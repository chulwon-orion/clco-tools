# clco-tools Config
# ==========================================
# Copy this file to .env.clco and fill in your values.
# .env.clco-example -> committed to git (no secrets)
# .env.clco         -> gitignored (your personal values)
#
# Used by: clco-notify (Slack) and clco-wiki (Confluence)
# Global:  ~/.claude/.env.clco          (applies to all projects)
# Project: <project-root>/.env.clco     (overrides global values)


# ==========================================
# clco-notify (Slack Notifications)
# ==========================================

# [REQUIRED] Slack Bot Token
# Create at: https://api.slack.com/apps -> OAuth & Permissions -> Bot Token (xoxb-...)
# Required scope: chat:write  (+ users:read.email if using --email lookup)
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# [OPTIONAL] App-level token and Signing Secret
# Not needed for outgoing notifications - include if your app uses them elsewhere
SLACK_APP_TOKEN=xapp-your-app-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here

# DO_NOT_DELETE_THIS_COMMENT_BLOCK
# clco-notify Project Config
# ==========================================

# [REQUIRED for DM] Target user - one of the two below must be set to receive DMs
#
# Option A: Slack User ID (recommended, no extra API call)
#   How to find: Slack -> click on username -> ... (three dots) -> Copy member ID
#   Example: U0123456789
#   Setup:   python3 setup_clco_notify.py --user-id U0123456789
SLACK_NOTIFY_USER_ID=

# Option B: Email (requires users:read.email scope on your bot)
#   If both are set, User ID takes precedence.
#   Setup:   python3 setup_clco_notify.py --email your.name@company.com
SLACK_NOTIFY_USER_EMAIL=


# [OPTIONAL] Post to a channel instead of (or in addition to) DM
#   Format: #channel-name  or  C0123456789 (channel ID)
#   If USER_ID/EMAIL is set, that takes precedence over this.
SLACK_NOTIFY_CHANNEL=


# [OPTIONAL] Project name shown in notifications
#   Useful when sharing one bot across multiple projects.
#   Example: SquidPBackend
SLACK_NOTIFY_PROJECT_NAME=

# [OPTIONAL] Message truncation lengths (characters)
SLACK_NOTIFY_LAST_PROMPT_MAXLEN=150
SLACK_NOTIFY_EVENT_MESSAGE_MAXLEN=200

# [OPTIONAL] Delay before sending notification (seconds)
#   If you respond within this time, the notification is cancelled.
#   Applies to both Stop and Notification events.
#   Set to 0 to send immediately (no cancellation window).
SLACK_NOTIFY_DELAY_SECONDS=60


# ==========================================
# clco-wiki (Confluence Sync)
# ==========================================

# [REQUIRED] Confluence base URL (without trailing slash)
# Example: https://yourcompany.atlassian.net/wiki
CONFLUENCE_BASE_URL=

# Atlassian account email
CONFLUENCE_USERNAME=

# Atlassian API token
# Generate at: https://id.atlassian.com/manage-profile/security/api-tokens
CONFLUENCE_API_TOKEN=

# [OPTIONAL] Default space key for new pages (e.g. MYSPACE, ENG, WIKI)
CONFLUENCE_SPACE_KEY=

# Default parent page ID (numeric); new pages are created under this page
CONFLUENCE_PARENT_PAGE_ID=922814104

# Project name label shown in page metadata (optional)
CONFLUENCE_PROJECT_NAME=
